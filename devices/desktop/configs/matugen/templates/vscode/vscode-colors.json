	"editor.tokenColorCustomizations": {
		"textMateRules": [
			{
				"scope": [
					"punctuation.definition.string.begin",
					"punctuation.definition.string.end",
					"punctuation.definition.string",
					"punctuation.definition.raw",
					"markup.inline.raw"
				],
				"settings": {
					"foreground": "{{colors.primary.default.hex}}"
				}
			},
			{
				"scope": [
					"markup.underline"
				],
				"settings": {
					"foreground": "{{colors.tertiary.default.hex}}",
					"fontStyle": "underline"
				}
			},
			{
				"scope": [
					"constant.other.placeholder",
					"constant.character.escape",
					"constant.language"
				],
				"settings": {
					"foreground": "{{colors.tertiary.default.hex}}",
					"fontStyle": "bold"
				}
			},
			{
				"scope": [
					"variable.parameter"
				],
				"settings": {
					"foreground": "{{colors.tertiary.default.hex}}",
					"fontStyle": "italic"
				}
			},
			{
				"scope": [
					"variable.other"
				],
				"settings": {
					"foreground": "{{colors.on_surface.default.hex}}",
					"fontStyle": "italic"
				}
			},
			{
				"scope": [
					"keyword.other.unit"
				],
				"settings": {
					"foreground": "{{colors.primary.default.hex}}"
				}
			}
		],
		"numbers": "{{colors.tertiary.default.hex}}",
		"strings": "{{colors.primary.default.hex}}"
	},
	"editor.semanticTokenColorCustomizations": {
		"rules": {
			"number": "{{colors.primary.default.hex}}",
			"string": "{{colors.primary.default.hex}}",
			"boolean": "{{colors.tertiary.default.hex}}"
		}
	}
}
