  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": [
          "punctuation.definition.string.begin",
          "punctuation.definition.string.end",
          "punctuation.definition.string",
          "punctuation.definition.raw",
          "markup.inline.raw"
        ],
        "settings": {
          "foreground": "#a5c8ff"
        }
      },
      {
        "scope": [
          "markup.underline"
        ],
        "settings": {
          "foreground": "#dabde2",
          "fontStyle": "underline"
        }
      },
      {
        "scope": [
          "constant.other.placeholder",
          "constant.character.escape",
          "constant.language"
        ],
        "settings": {
          "foreground": "#dabde2",
          "fontStyle": "bold"
        }
      },
      {
        "scope": [
          "variable.parameter"
        ],
        "settings": {
          "foreground": "#dabde2",
          "fontStyle": "italic"
        }
      },
      {
        "scope": [
          "variable.other"
        ],
        "settings": {
          "foreground": "#e1e2e9",
          "fontStyle": "italic"
        }
      },
      {
        "scope": [
          "keyword.other.unit"
        ],
        "settings": {
          "foreground": "#a5c8ff"
        }
      }
    ],
    "numbers": "#dabde2",
    "strings": "#a5c8ff"
  },
  "editor.semanticTokenColorCustomizations": {
    "rules": {
      "number": "#a5c8ff",
      "string": "#a5c8ff",
      "boolean": "#dabde2"
    }
  },
