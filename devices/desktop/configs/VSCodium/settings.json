        "color": "#e78284"
      },
      "light": {
        "backgroundColor": "#fcd7d7",
        "color": "#d20f39"
      }
    },
    {
      "keywords": [
        "important",
        "critical"
      ],
      "fontWeight": "bold",
      "dark": {
        "backgroundColor": "#45475a",
        "color": "#f2d5cf"
      },
      "light": {
        "backgroundColor": "#e9ecef",
        "color": "#5c2e2e"
